{% extends 'base.html.twig' %}

{% block title %}Aggiungi movimento{% endblock %}

{% block body %}
    <div class="container py-4">
        <h1 class="mb-3">Aggiungi un movimento</h1>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} mb-3">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        {{ form_start(form) }}
        <div class="row g-3">
            <div class="col-md-4">
                {{ form_label(form.amount) }}
                {{ form_widget(form.amount, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.amount) }}
            </div>

            <div class="col-md-8">
                {{ form_label(form.description) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'maxlength': 100}}) }}
                <div class="form-text">Max 100 caratteri.</div>
                {{ form_errors(form.description) }}
            </div>

            <div class="col-md-4">
                {{ form_label(form.date) }}
                {{ form_widget(form.date, {'attr': {'class': 'form-control'}}) }}
                <div class="form-text">Non sono permesse date future.</div>
                {{ form_errors(form.date) }}
            </div>

            <div class="col-md-4">
                {{ form_label(form.type) }}
                <div class="form-control p-2">
                    {{ form_widget(form.type) }}
                </div>
                {{ form_errors(form.type) }}
            </div>

            <div class="col-md-4" id="category-wrapper">
                {{ form_label(form.category) }}
                {{ form_widget(form.category, {'attr': {'class': 'form-select'}}) }}
                {{ form_errors(form.category) }}
            </div>
        </div>

        <div class="mt-4">
            <button class="btn btn-primary">Salva</button>
            <a class="btn btn-outline-secondary" href="{{ path('movement_index') }}">Annulla</a>
        </div>
        {{ form_end(form) }}
    </div>

    {# Toggle visibilitÃ  categoria in base al tipo #}
    <script>
        (function() {
            const radios = document.querySelectorAll('input[name="{{ form.type.vars.full_name }}"]');
            const wrap = document.getElementById('category-wrapper');
            const select = wrap ? wrap.querySelector('select') : null;

            function onTypeChange() {
                const selected = [...radios].find(r => r.checked)?.value; // 'income' | 'expense'
                const isExpense = selected === 'expense';
                if (wrap) wrap.style.display = isExpense ? '' : 'none';
                if (select) select.required = isExpense;
                if (!isExpense && select) select.value = '';
            }

            radios.forEach(r => r.addEventListener('change', onTypeChange));
            onTypeChange(); // init
        })();
    </script>
{% endblock %}